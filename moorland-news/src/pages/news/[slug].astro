---
import { Client } from "@notionhq/client";
import { NotionToMarkdown } from "notion-to-md";

// 1. THE BULLETPROOF FIX: Fetch all paths directly via clean HTTP network request
export async function getStaticPaths() {
  const token = import.meta.env.NOTION_TOKEN;
  const dbId = import.meta.env.NOTION_DATABASE_ID;

  try {
    const res = await fetch(`https://api.notion.com/v1/databases/${dbId}/query`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Notion-Version': '2022-06-28',
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        filter: {
          property: 'Published',
          checkbox: { equals: true }
        }
      })
    });

    const data = await res.json();

    if (!data.results) {
      console.error("Notion API returned no rows:", data);
      return [];
    }

    // Filter out rows missing a slug, then pass parameters down
    return data.results
      .filter((post: any) => post.properties?.Slug?.rich_text?.[0]?.plain_text)
      .map((post: any) => {
        const slugText = post.properties.Slug.rich_text[0].plain_text;
        return {
          params: { slug: slugText },
          props: { post }, // Pass down the raw post object data
        };
      });

  } catch (error) {
    console.error("❌ Native Fetch failed inside getStaticPaths:", error);
    return [];
  }
}

const { slug } = Astro.params;
const { post } = Astro.props as any;

// 2. Extract your Title string securely from the passed down properties
const rawDate = post?.properties?.Date?.date?.start || "";
const postDate = rawDate 
  ? new Date(rawDate).toLocaleDateString('en-GB', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric'
    })
  : "";
const postTitle = post?.properties?.Name?.title?.[0]?.plain_text || "Newsletter"; 

// 3. Convert the individual page block body below into HTML layouts
// Note: We use a lightweight manual fallback initialization here so it bypasses constructor crashes
let articleContentHtml = "<p>No content written for this article yet.</p>";

if (post) {
  try {
    // Standard client fallback container
    const rawClient = new (Client as any)({ auth: import.meta.env.NOTION_TOKEN });
    const n2m = new NotionToMarkdown({ notionClient: rawClient });
    
    const mdblocks = await n2m.pageToMarkdown(post.id);
    const mdString = n2m.toMarkdownString(mdblocks);
    articleContentHtml = mdString.parent || "<p>No content written for this article yet.</p>";
  } catch (e) {
    console.error("Error parsing content blocks:", e);
    articleContentHtml = "<p>Error displaying written content layout stream.</p>";
  }
}
