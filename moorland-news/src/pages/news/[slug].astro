---
import { Client } from "@notionhq/client";
import { NotionToMarkdown } from "notion-to-md";

/**
 * REQUIRED for /news/[slug]
 */
export async function getStaticPaths() {
  const token = import.meta.env.NOTION_TOKEN;
  const dbId = import.meta.env.NOTION_DATABASE_ID;

  const res = await fetch(
    `https://api.notion.com/v1/databases/${dbId}/query`,
    {
      method: "POST",
      headers: {
        Authorization: `Bearer ${token}`,
        "Notion-Version": "2022-06-28",
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        filter: {
          property: "Published",
          checkbox: { equals: true },
        },
      }),
    }
  );

  const data = await res.json();

  return (data.results || [])
    .filter(
      (post) =>
        post.properties?.Slug?.rich_text?.[0]?.plain_text
    )
    .map((post) => ({
      params: {
        slug: post.properties.Slug.rich_text[0].plain_text,
      },
      props: { post },
    }));
}

const notion = new Client({
  auth: import.meta.env.NOTION_TOKEN,
});

const n2m = new NotionToMarkdown({
  notionClient: notion,
});

/**
 * IMAGE TRANSFORMER
 */
n2m.setCustomTransformer("image", async (block) => {
  const imageUrl =
    block.image?.file?.url ||
    block.image?.external?.url ||
    "";

  const imageAlt =
    block.image?.caption?.[0]?.plain_text ||
    "Notion image";

  if (!imageUrl) return "";

  return `
    <img 
      src="${imageUrl}" 
      alt="${imageAlt}" 
      class="notion-image"
      loading="lazy"
    />
  `;
});

const { post } = Astro.props;

const rawDate = post?.properties?.Date?.date?.start || "";
const postDate = rawDate
  ? new Date(rawDate).toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    })
  : "";

const postTitle =
  post?.properties?.Name?.title?.[0]?.plain_text ||
  "Newsletter";

let articleContentHtml =
  "<p>No content written for this article yet.</p>";

if (post) {
  try {
    const mdBlocks = await n2m.pageToMarkdown(post.id);
    const mdString = n2m.toMarkdownString(mdBlocks);

    let html = mdString.parent || "";

    html = html.replace(
      /!\[(.*?)\]\((.*?)\)/g,
      (_, alt, src) => {
        return `<img src="${src}" alt="${
          alt || "Notion image"
        }" class="notion-image" loading="lazy" />`;
      }
    );

    articleContentHtml = html;
  } catch (e) {
    console.error(e);
    articleContentHtml = "<p>Error loading article.</p>";
  }
}
---

