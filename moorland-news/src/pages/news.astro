---
// 1. THE BRAIN: Fetching from Notion
const token = import.meta.env.NOTION_TOKEN;
const dbId = import.meta.env.NOTION_DATABASE_ID;

let newsItems = [];

try {
  const res = await fetch(`https://api.notion.com/v1/databases/${dbId}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      filter: {
        property: 'Published',
        checkbox: { equals: true }
      },
      sorts: [
        { property: 'Date', direction: 'descending' }
      ]
    })
  });

  const data = await res.json();

  if (data.results) {
    newsItems = data.results.map((page: any) => ({
      id: page.id,
      title: page.properties.Name?.title[0]?.plain_text || 'Untitled Post',
      slug: page.properties.Slug?.rich_text[0]?.plain_text || '',
      date: page.properties.Date?.date?.start || 'No Date',
    }));
  }
} catch (error) {
  console.error("Failed to connect to Notion:", error);
}
