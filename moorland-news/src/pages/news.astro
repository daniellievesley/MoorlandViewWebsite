---
// 1. Fetch all your news rows from the Notion API via a clean network request
const token = import.meta.env.NOTION_TOKEN;
const dbId = import.meta.env.NOTION_DATABASE_ID;

let newsItems = [];

try {
  const res = await fetch(`https://api.notion.com/v1/databases/${dbId}/query`, {
    method: "POST",
    headers: {
      Authorization: `Bearer ${token}`,
      "Notion-Version": "2022-06-28",
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      filter: {
        property: "Published",
        checkbox: { equals: true },
      },
    }),
  });

  const data = await res.json();
  newsItems = data.results || [];
} catch (error) {
  console.error("Failed to fetch news grid items from Notion:", error);
}
